@prefix wsi: <http://example.org/wsi-workflow#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

wsi:Research_Paper_Sample rdf:type wsi:Research_Paper ;
    wsi:hasPurpose "Sample purpose description here." ;
    wsi:hasGithubRepo "https://github.com/sample/repo" ;
    wsi:hasMethodology wsi:CLAM .

wsi:CLAM rdf:type wsi:WSI_Step ;
    wsi:hasInputFormat wsi:SVS ;
    wsi:hasOutputFormat wsi:H5 ;
    wsi:usesAlgorithm wsi:ResNet50 ;
    wsi:nextStep wsi:Instance_Level_Clustering .

wsi:Instance_Level_Clustering rdf:type wsi:WSI_Step ;
    wsi:hasInputFormat wsi:H5 ;
    wsi:hasOutputFormat wsi:H5 ;
    wsi:usesAlgorithm wsi:Smooth_SVM_Loss ;
    wsi:nextStep wsi:Model_Selection .

wsi:Model_Selection rdf:type wsi:WSI_Step ;
    wsi:hasInputFormat wsi:H5 ;
    wsi:hasOutputFormat wsi:H5 ;
    wsi:usesAlgorithm wsi:Early_Stopping ;
    wsi:nextStep wsi:Training_Details .

wsi:Training_Details rdf:type wsi:WSI_Step ;
    wsi:hasInputFormat wsi:H5 ;
    wsi:hasOutputFormat wsi:H5 ;
    wsi:usesAlgorithm wsi:Adam_Optimizer ;
    wsi:nextStep wsi:Model_Selection .

wsi:ResNet50 rdf:type wsi:Algorithm ;
    wsi:hasParameter wsi:Patch_Size=256 ;
    wsi:hasParameter wsi:Batch_Size=128 .

wsi:Smooth_SVM_Loss rdf:type wsi:Algorithm ;
    wsi:hasParameter wsi:Margin=1.0 ;
    wsi:hasParameter wsi:Temperature_Scaling=1.0 .

wsi:Early_Stopping rdf:type wsi:Algorithm ;
    wsi:hasParameter wsi:Patience=20 ;
    wsi:hasParameter wsi:Min_Delta=0.0 .

wsi:Adam_Optimizer rdf:type wsi:Algorithm ;
    wsi:hasParameter wsi:Learning_Rate=2e-4 ;
    wsi:hasParameter wsi:Weight_Decay=1e-5 .
