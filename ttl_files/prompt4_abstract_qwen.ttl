wsi:Research_Paper_CLAM rdf:type wsi:Research_Paper ;
    wsi:hasPurpose "A high-throughput, interpretable, and data-efficient weakly-supervised WSI-level classification method that only requires slide-level labels, enabling multi-class subtyping, domain adaptation, and interpretability without spatial annotations." ;
    wsi:hasGithubRepo "https://github.com/mahmoodlab/CLAM" ;
    wsi:hasMethodology wsi:Patch_Extraction .

wsi:Patch_Extraction rdf:type wsi:WSI_Step ;
    wsi:hasInputFormat wsi:SVS ;
    wsi:hasOutputFormat wsi:H5 ;
    wsi:usesAlgorithm wsi:ResNet50 ;
    wsi:nextStep wsi:Feature_Extraction .

wsi:Feature_Extraction rdf:type wsi:WSI_Step ;
    wsi:hasInputFormat wsi:H5 ;
    wsi:hasOutputFormat wsi:H5 ;
    wsi:usesAlgorithm wsi:ResNet50 ;
    wsi:nextStep wsi:Attention_Pooling .

wsi:Attention_Pooling rdf:type wsi:WSI_Step ;
    wsi:hasInputFormat wsi:H5 ;
    wsi:hasOutputFormat wsi:H5 ;
    wsi:usesAlgorithm wsi:Attention_Based_Pooling ;
    wsi:nextStep wsi:Instance_Level_Clustering .

wsi:Instance_Level_Clustering rdf:type wsi:WSI_Step ;
    wsi:hasInputFormat wsi:H5 ;
    wsi:hasOutputFormat wsi:H5 ;
    wsi:usesAlgorithm wsi:Clustering_Layer ;
    wsi:nextStep wsi:Slide_Level_Classification .

wsi:Slide_Level_Classification rdf:type wsi:WSI_Step ;
    wsi:hasInputFormat wsi:H5 ;
    wsi:hasOutputFormat wsi:H5 ;
    wsi:usesAlgorithm wsi:Cross_Entropy_Loss ;
    wsi:nextStep wsi:Visualization .

wsi:Visualization rdf:type wsi:WSI_Step ;
    wsi:hasInputFormat wsi:H5 ;
    wsi:hasOutputFormat wsi:TIFF ;
    wsi:usesAlgorithm wsi:Attention_Heatmap ;
    wsi:nextStep wsi:End .

wsi:ResNet50 rdf:type wsi:Algorithm ;
    wsi:hasParameter wsi:patch_size_256 ;
    wsi:hasParameter wsi:pretrained_ImageNet ;
    wsi:hasParameter wsi:adaptive_mean_pooling_3rd_residual_block .

wsi:Attention_Based_Pooling rdf:type wsi:Algorithm ;
    wsi:hasParameter wsi:multi_class_attention ;
    wsi:hasParameter wsi:trainable_attention_pooling ;
    wsi:hasParameter wsi:softmax_normalization .

wsi:Clustering_Layer rdf:type wsi:Algorithm ;
    wsi:hasParameter wsi:512_hidden_units ;
    wsi:hasParameter wsi:binary_clustering ;
    wsi:hasParameter wsi:mutual_exclusivity_assumption .

wsi:Cross_Entropy_Loss rdf:type wsi:Algorithm ;
    wsi:hasParameter wsi:cross_entropy_classification_loss ;
    wsi:hasParameter wsi:slide_level_label_supervision .

wsi:Attention_Heatmap rdf:type wsi:Algorithm ;
    wsi:hasParameter wsi:percentile_normalization ;
    wsi:hasParameter wsi:diverging_colormap ;
    wsi:hasParameter wsi:transparency_0.5 .

wsi:SVS rdf:type wsi:Data_Format .
wsi:H5 rdf:type wsi:Data_Format .
wsi:TIFF rdf:type wsi:Data_Format .
wsi:patch_size_256 rdf:type wsi:Parameter .
wsi:pretrained_ImageNet rdf:type wsi:Parameter .
wsi:adaptive_mean_pooling_3rd_residual_block rdf:type wsi:Parameter .
wsi:multi_class_attention rdf:type wsi:Parameter .
wsi:trainable_attention_pooling rdf:type wsi:Parameter .
wsi:softmax_normalization rdf:type wsi:Parameter .
wsi:512_hidden_units rdf:type wsi:Parameter .
wsi:binary_clustering rdf:type wsi:Parameter .
wsi:mutual_exclusivity_assumption rdf:type wsi:Parameter .
wsi:cross_entropy_classification_loss rdf:type wsi:Parameter .
wsi:slide_level_label_supervision rdf:type wsi:Parameter .
wsi:percentile_normalization rdf:type wsi:Parameter .
wsi:diverging_colormap rdf:type wsi:Parameter .
wsi:transparency_0.5 rdf:type wsi:Parameter .
