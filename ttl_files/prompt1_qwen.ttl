<https://example.org/wsi-workflow#CLAM_Paper> a wsi:Research_Paper ;
    wsi:hasPurpose "A high-throughput deep learning toolbox for weakly-supervised classification of whole slide images (WSIs) in computational pathology using clustering-constrained attention multiple instance learning (CLAM)" ;
    wsi:hasGithubRepo <https://github.com/mahmoodlab/CLAM> ;
    wsi:hasMethodology wsi:Patch_Extraction .

wsi:Patch_Extraction a wsi:WSI_Step ;
    wsi:hasInputFormat wsi:SVS ;
    wsi:hasOutputFormat wsi:H5 ;
    wsi:usesAlgorithm wsi:ResNet50 ;
    wsi:nextStep wsi:Feature_Extraction .

wsi:Feature_Extraction a wsi:WSI_Step ;
    wsi:hasInputFormat wsi:H5 ;
    wsi:hasOutputFormat wsi:H5 ;
    wsi:usesAlgorithm wsi:ResNet50 ;
    wsi:hasParameter wsi:patch_size_256 ;
    wsi:hasParameter wsi:magnification_20x ;
    wsi:hasParameter wsi:batch_size_128 ;
    wsi:nextStep wsi:Classification .

wsi:Classification a wsi:WSI_Step ;
    wsi:hasInputFormat wsi:H5 ;
    wsi:hasOutputFormat wsi:CSV ;
    wsi:usesAlgorithm wsi:CLAM ;
    wsi:hasParameter wsi:attention_branches_n ;
    wsi:hasParameter wsi:clustering_B_8 ;
    wsi:hasParameter wsi:loss_c1_0.7 ;
    wsi:hasParameter wsi:loss_c2_0.3 ;
    wsi:hasParameter wsi:learning_rate_2e-4 ;
    wsi:hasParameter wsi:weight_decay_1e-5 ;
    wsi:hasParameter wsi:early_stopping_patience_20 ;
    wsi:hasParameter wsi:epochs_50_to_200 ;
    wsi:hasParameter wsi:adam_optimizer ;
    wsi:hasParameter wsi:smooth_SVM_loss ;
    wsi:hasParameter wsi:mutual_exclusivity_assumption ;
    wsi:hasParameter wsi:multinomial_sampling ;
    wsi:nextStep wsi:Visualization .

wsi:Visualization a wsi:WSI_Step ;
    wsi:hasInputFormat wsi:CSV ;
    wsi:hasOutputFormat wsi:PNG ;
    wsi:usesAlgorithm wsi:PCA ;
    wsi:usesAlgorithm wsi:Attention_Heatmap ;
    wsi:hasParameter wsi:components_50 ;
    wsi:hasParameter wsi:colormap_diverging ;
    wsi:hasParameter wsi:transparency_0.5 ;
    wsi:hasParameter wsi:overlap_95_percent ;
    wsi:hasParameter wsi:percentile_normalization .
